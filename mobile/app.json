{
  "expo": {
    "name": "Spotify Clone",
    "slug": "spotify-clone",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": { "supportsTablet": true, "bundleIdentifier": "com.demo.spotifyclone" },
    "android": {
      "package": "com.demo.spotifyclone",
      "adaptiveIcon": { "backgroundColor": "#000000" }
    },
    "web": { "bundler": "metro" }
  }
}
